RewriteEngine On

# ป้องกันไม่ให้เข้าถึง src โดยตรง
RewriteCond %{THE_REQUEST} \s/src/ [NC]
RewriteRule ^src/(.*)$ /$1 [R=301,L]

# ถ้าไฟล์/โฟลเดอร์มีอยู่จริงใน src ให้ส่งไปที่ src/
RewriteCond %{REQUEST_URI} !^/src/
RewriteCond %{DOCUMENT_ROOT}/src%{REQUEST_URI} -f [OR]
RewriteCond %{DOCUMENT_ROOT}/src%{REQUEST_URI} -d
RewriteRule ^(.*)$ src/$1 [L]

# ถ้าไม่มีนามสกุล ให้เพิ่ม .php อัตโนมัติ (ในโฟลเดอร์ src)
RewriteCond %{REQUEST_URI} !^/src/
RewriteCond %{DOCUMENT_ROOT}/src%{REQUEST_URI}.php -f
RewriteRule ^(.*)$ src/$1.php [L]

# ถ้าไม่เจอไฟล์เลย → 404
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ 404.php [L]